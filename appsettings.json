{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MusicServer": {
    "DbPath": "Data/catclaw.db",
    "MusicDirectory": "D:\\Music",
    "CoverOutputDir": "Data/covers",
    "AccessToken": "catclaw-internal-token-change-me",
    "AdminUser": "admin",
    "AdminPassword": ""
  },
  "Jwt": {
    "SecretKey": "CatClawMusic-Default-Secret-Change-In-Production-2024!",
    "Issuer": "CatClawMusicServer",
    "Audience": "CatClawMusicClient",
    "AccessTokenExpireMinutes": 15,
    "RefreshTokenExpireDays": 30
  },
  "Streaming": {
    "HlsEnabled": true,
    "TranscodeCacheSizeGB": 2,
    "FFmpegPath": "ffmpeg",
    "SegmentDurationSeconds": 6,
    "MaxConcurrentTranscodes": 4,
    "DefaultBitrates": "96,160,256",
    "TranscodeDir": "Data/transcode"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 200
      },
      {
        "Endpoint": "*/api/songs/*/stream",
        "Period": "1m",
        "Limit": 60
      }
    ]
  }
}
